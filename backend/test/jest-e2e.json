{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "testTimeout": 60000,
  "globals": {
    "ts-jest": {
      "tsconfig": {
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true
      }
    }
  }
}
