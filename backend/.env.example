# Application
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# PostgreSQL — Supabase, local Docker, or managed Postgres
DB_HOST=db.your-project-ref.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-database-password
DB_NAME=postgres
DB_SSL=true
DB_SYNCHRONIZE=true

# Redis — local Docker, Redis Cloud, or managed Redis
REDIS_HOST=your-redis-host.db.redis.io
REDIS_PORT=16396
REDIS_USERNAME=default
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# Cache (redis | memory)
CACHE_STORE=redis
CACHE_TTL_MS=300000

# Rate limiting (Redis-backed when THROTTLE_USE_REDIS=true)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
THROTTLE_USE_REDIS=true

# Row-Level Security auto-apply on startup (after tables exist)
RLS_AUTO_APPLY=true

# Feature flags (set to false to disable)
FEATURE_PAYMENTS=true
FEATURE_INVITES=true
FEATURE_REALTIME=true
FEATURE_AUDIT_LOGS=true
FEATURE_RATE_LIMITING=true

# JWT - RS256 keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_SECRET=dev-secret-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Payment provider: mock | stripe | razorpay
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# OpenTelemetry (imported at startup via src/tracing.ts)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=saas-workspace-api
